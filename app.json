{
  "expo": {
    "name": "Mora - Calorie Tracker",
    "slug": "mora",
    "scheme": "mora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios-light.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icons/splash-icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": {
        "light": "./assets/icons/ios-light.png",
        "dark": "./assets/icons/ios-dark.png",
        "tinted": "./assets/icons/ios-tinted.png"
      },
      "splash": {
        "image": "./assets/icons/splash-icon-light.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "image": "./assets/icons/splash-icon-dark.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.schroedernathan.mora",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Mora to use speech recognition for voice food logging.",
        "NSMicrophoneUsageDescription": "Allow Mora to use your microphone for voice food logging.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow Mora to access your photo library to attach food photos."
      }
    },
    "android": {
      "icon": "./assets/icons/ios-light.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/adaptive-icon.png"
      },
      "splash": {
        "image": "./assets/icons/splash-icon-light.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "image": "./assets/icons/splash-icon-dark.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      },
      "package": "com.schroedernathan.mora",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "server"
    },
    "plugins": [
      "expo-image",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Satoshi-Variable.ttf",
            "./assets/fonts/Satoshi-VariableItalic.ttf",
            "./assets/fonts/Sentient-Variable.ttf",
            "./assets/fonts/Sentient-VariableItalic.ttf"
          ]
        }
      ],
      "expo-sqlite",
      "expo-router",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Mora to use your microphone for voice food logging.",
          "speechRecognitionPermission": "Allow Mora to use speech recognition for voice food logging."
        }
      ],
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "Allow Mora to use your microphone for voice food logging."
        }
      ]
    ],
    "owner": "schroedernathan",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ebd281d-28ed-45f7-bc02-a804c4a3e937"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0ebd281d-28ed-45f7-bc02-a804c4a3e937"
    }
  }
}
